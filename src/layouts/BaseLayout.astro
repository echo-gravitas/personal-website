---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MainContainer from '../components/MainContainer.astro';
import { defaultTheme, themeTokens } from '../scripts/themes';
import '../styles/global.css';

type Props = {
  canonicalPath?: string;
  description?: string;
  imageAlt?: string;
  imagePath?: string;
  keywords?: string[];
  ogType?: 'article' | 'profile' | 'website';
  structuredData?: Record<string, unknown>;
  title?: string;
};

const siteUrl = 'https://seventrees.io';
const defaultTitle = 'Ralph Bolliger · UX Design für komplexe digitale Systeme';
const defaultDescription =
  'Ralph Bolliger gestaltet UX, Produktdesign und digitale Resilienz für komplexe Systeme. Klar, sicher und nutzerzentriert.';

const defaultStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  'mainEntity': {
    '@type': 'Person',
    'name': 'Ralph Bolliger',
    'url': 'https://seventrees.io/',
    'jobTitle': 'UX Designer, Product Designer und Security Researcher',
    'description':
      'Ralph Bolliger gestaltet UX, Produktdesign und digitale Resilienz für komplexe digitale Systeme.',
    'knowsAbout': [
      'UX Design',
      'Product Design',
      'Cyber Security',
      'Digital Resilience',
      'Communication Systems',
      'Human-Centered Technology',
    ],
  },
};

const {
  canonicalPath = '/',
  description = defaultDescription,
  imageAlt,
  imagePath,
  keywords = [],
  ogType = 'website',
  structuredData = defaultStructuredData,
  title = defaultTitle,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const imageUrl = imagePath ? new URL(imagePath, siteUrl).toString() : undefined;
---

<!doctype html>
<html lang='de'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' href='/img/favicon.svg' />
    <link rel='canonical' href={canonicalUrl} />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='description' content={description} />
    {keywords.length > 0 && <meta name='keywords' content={keywords.join(', ')} />}
    <meta property='og:site_name' content='Ralph Bolliger' />
    <meta property='og:locale' content='de_CH' />
    <meta property='og:type' content={ogType} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonicalUrl} />
    {imageUrl && <meta property='og:image' content={imageUrl} />}
    {imageAlt && <meta property='og:image:alt' content={imageAlt} />}
    <meta name='twitter:card' content={imageUrl ? 'summary_large_image' : 'summary'} />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    {imageUrl && <meta name='twitter:image' content={imageUrl} />}
    {imageAlt && <meta name='twitter:image:alt' content={imageAlt} />}
    <script
      type='application/ld+json'
      set:html={JSON.stringify(structuredData)}
    />
    <script async src='https://www.googletagmanager.com/gtag/js?id=G-E259F43NWW'
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());

      gtag('config', 'G-E259F43NWW');
    </script>
    <script define:vars={{ defaultTheme, themeTokens }}>
      const themes = Object.keys(themeTokens);
      let theme =
        themes[Math.floor(Math.random() * themes.length)] ?? defaultTheme;

      try {
        const storedTheme = localStorage.getItem('theme');
        const hasStoredTheme = Object.prototype.hasOwnProperty.call(
          themeTokens,
          storedTheme,
        );

        if (hasStoredTheme) {
          theme = storedTheme;
        } else {
          localStorage.setItem('theme', theme);
        }
      } catch {}

      document.documentElement.dataset.theme = theme;

      Object.entries(themeTokens[theme]).forEach(([token, value]) => {
        document.documentElement.style.setProperty(`--theme-${token}`, value);
      });
    </script>
    <title>{title}</title>
  </head>
  <body>
    <MainContainer>
      <Header />
      <slot />
      <Footer />
    </MainContainer>
    <script>
      import '../scripts/main';
    </script>
  </body>
</html>
