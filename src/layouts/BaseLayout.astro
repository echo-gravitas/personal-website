---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MainContainer from '../components/MainContainer.astro';
import { defaultTheme, themeTokens } from '../scripts/themes';
import '../styles/global.css';

const { title } = Astro.props;
const pageTitle = title
  ? `${title}`
  : 'Designing technology for humans - Ralph Bolliger';
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' href='/img/favicon.svg' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta
      name='description'
      content='Designing technology for humans through experience design, software development, communication systems, and security research.'
    />
    <meta name='credo' content='Going dark is no longer an option.' />
    <script define:vars={{ defaultTheme, themeTokens }}>
      const themes = Object.keys(themeTokens);
      let theme = themes[Math.floor(Math.random() * themes.length)] ?? defaultTheme;

      try {
        const storedTheme = localStorage.getItem('theme');
        const hasStoredTheme = Object.prototype.hasOwnProperty.call(
          themeTokens,
          storedTheme,
        );

        if (hasStoredTheme) {
          theme = storedTheme;
        } else {
          localStorage.setItem('theme', theme);
        }
      } catch {}

      document.documentElement.dataset.theme = theme;

      Object.entries(themeTokens[theme]).forEach(([token, value]) => {
        document.documentElement.style.setProperty(`--theme-${token}`, value);
      });
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <MainContainer>
      <Header />
      <slot />
      <Footer />
    </MainContainer>
    <script>
      import '../scripts/main';
    </script>
  </body>
</html>
