---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MainContainer from '../components/MainContainer.astro';
import { defaultTheme, themeTokens } from '../scripts/themes';
import '../styles/global.css';

const { title } = Astro.props;
const pageTitle = title
  ? `${title}`
  : 'Ralph Bolliger — Senior Product Designer';
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' href='/img/favicon.svg' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta
      name='description'
      content='I design resilient systems by questioning defaults. Skeptical by default. Responsible by design.'
    />
    <meta name='credo' content='Going dark is no longer an option.' />
    <script define:vars={{ defaultTheme, themeTokens }}>
      let theme = defaultTheme;

      try {
        const storedTheme = localStorage.getItem('theme');
        theme = Object.prototype.hasOwnProperty.call(themeTokens, storedTheme)
          ? storedTheme
          : theme;
      } catch {}

      document.documentElement.dataset.theme = theme;

      Object.entries(themeTokens[theme]).forEach(([property, value]) => {
        document.documentElement.style.setProperty(property, value);
      });
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <MainContainer>
      <Header />
      <slot />
      <Footer />
    </MainContainer>
    <script src='../scripts/main.js'></script>
  </body>
</html>
