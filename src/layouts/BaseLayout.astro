---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import MainContainer from '../components/MainContainer.astro';
import { defaultTheme, themeTokens } from '../scripts/themes';
import '../styles/global.css';

const { title } = Astro.props;
const pageTitle = title
  ? `${title}`
  : 'Ralph Bolliger · UX Design für komplexe digitale Systeme';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  'mainEntity': {
    '@type': 'Person',
    'name': 'Ralph Bolliger',
    'url': 'https://seventrees.io/',
    'jobTitle': 'UX Designer, Product Designer und Security Researcher',
    'description':
      'Ralph Bolliger gestaltet UX, Produktdesign und digitale Resilienz für komplexe digitale Systeme.',
    'knowsAbout': [
      'UX Design',
      'Product Design',
      'Cyber Security',
      'Digital Resilience',
      'Communication Systems',
      'Human-Centered Technology',
    ],
  },
};
---

<!doctype html>
<html lang='de'>
  <head>
    <meta charset='utf-8' />
    <link rel='icon' href='/img/favicon.svg' />
    <link rel='canonical' href='https://seventrees.io/' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta
      name='description'
      content='Ralph Bolliger gestaltet UX, Produktdesign und digitale Resilienz für komplexe Systeme. Klar, sicher und nutzerzentriert.'
    />
    <script
      type='application/ld+json'
      set:html={JSON.stringify(structuredData)}
    />
    <script async src='https://www.googletagmanager.com/gtag/js?id=G-E259F43NWW'
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('js', new Date());

      gtag('config', 'G-E259F43NWW');
    </script>
    <script define:vars={{ defaultTheme, themeTokens }}>
      const themes = Object.keys(themeTokens);
      let theme =
        themes[Math.floor(Math.random() * themes.length)] ?? defaultTheme;

      try {
        const storedTheme = localStorage.getItem('theme');
        const hasStoredTheme = Object.prototype.hasOwnProperty.call(
          themeTokens,
          storedTheme,
        );

        if (hasStoredTheme) {
          theme = storedTheme;
        } else {
          localStorage.setItem('theme', theme);
        }
      } catch {}

      document.documentElement.dataset.theme = theme;

      Object.entries(themeTokens[theme]).forEach(([token, value]) => {
        document.documentElement.style.setProperty(`--theme-${token}`, value);
      });
    </script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <MainContainer>
      <Header />
      <slot />
      <Footer />
    </MainContainer>
    <script>
      import '../scripts/main';
    </script>
  </body>
</html>
