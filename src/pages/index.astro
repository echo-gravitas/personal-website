---
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Columns from '../components/Columns.astro';
import Section from '../components/Section.astro';
import SplitList from '../components/SplitList.astro';
import LargeText from '../components/typography/LargeText.astro';
import LeadText from '../components/typography/LeadText.astro';
import NormalText from '../components/typography/NormalText.astro';
import ogImage from '../images/blog/boitumelo-o_tcYADlSt8-unsplash.jpg';
import portrait from '../images/portrait.jpg';

const optimizedOgImage = await getImage({
  src: ogImage,
  width: 1200,
  height: 630,
  format: 'jpg',
});

const howColumns = [
  {
    title: 'UX & Product Design',
    text: 'Ich mache komplexe Software verständlich und bedienbar. Aus unklaren Prozessen entstehen digitale Produkte, die Menschen sicher durch ihre Aufgaben führen.',
  },
  {
    title: 'Cyber Security & Resilienz',
    text: 'Ich denke Systeme aus Sicht von Angreifern, Nutzern und Organisationen, um Risiken früh sichtbar zu machen. Sicherheit darf nicht dem Zufall überlassen werden.',
  },
  {
    title: 'Elektronik & Kommunikation',
    text: 'Ich beschäftige mich mit Kommunikation als Infrastruktur: mit Protokollen, Metadaten, Funktechnik und unabhängigen Wegen, wenn Plattformen oder Netze ausfallen.',
  },
];

const pathItems = [
  {
    label: 'Digitale Kommunikation',
    value:
      'Meine Wurzeln liegen in der digitalen Kommunikation. Dort habe ich gelernt, wie stark Technologie Aufmerksamkeit, Verhalten und Vertrauen beeinflusst.',
  },
  {
    label: 'Projektmanagement',
    value:
      'Im Projektmanagement habe ich erlebt, was passiert, wenn gute Strategien auf tatsächliche Abhängigkeiten treffen. Seitdem verbinde ich technische Machbarkeit, klare Führung und menschliche Bedürfnisse.',
  },
  {
    label: 'Product & Experience Design',
    value:
      'Heute gestalte ich Interfaces, Workflows und digitale Produkte, die Orientierung schaffen. Mein Ziel sind Systeme, die ihre Komplexität tragen, ohne sie an die Nutzerinnen und Nutzer weiterzureichen.',
  },
  {
    label: 'Unabhängige und sichere Kommunikation',
    value:
      'Neben Kundenprojekten baue ich unabhängige Software, experimentiere mit Elektronik und Funktechnik, und engagiere mich für digitale Sicherheit. Mich interessiert, wie Menschen und Organisationen vernetzt, selbstbestimmt und widerstandsfähig bleiben.',
  },
];
const focusItems = [
  {
    title: 'Komplexe Interfaces',
    text: 'Ich arbeite an Produkten, bei denen Fehlinterpretationen teuer werden können. Dort braucht es klare Strukturen, nachvollziehbare Informationen und Interfaces, die auch unter Belastung funktionieren.',
  },
  {
    title: 'Digitale Produkte',
    text: 'Gute digitale Produkte respektieren Menschen. Privatsphäre, Transparenz und Autonomie entstehen nicht erst in Privacy Policies, sondern im Product Design, Protokolldetails und Geschäftsmodellen.',
  },
  {
    title: 'Systeme & Kommunikation',
    text: 'Mich reizen Projekte, bei denen unter der Oberfläche viel passiert: resiliente Infrastruktur, unabhängige Netzwerke, sichere Kommunikation und technische Umgebungen mit echten Anforderungen.',
  },
];
const rulesOnAI = [
  {
    title: '1. Menschliche Fähigkeiten müssen erhalten bleiben',
    text: 'KI kann menschliches Denken beschleunigen, sie darf es nicht ersetzen. Wer Denken dauerhaft delegiert, verliert die Fähigkeit, Ergebnisse kritisch zu prüfen. Menschen müssen verstehen, beurteilen und handeln können.',
  },
  {
    title: '2. Resilienz geht vor Effizienz und Wettbewerbsvorteil',
    text: 'Ein System, das nur auf Geschwindigkeit, Skalierung und Kosten optimiert ist, wird schnell verwundbar. Robust wird Technologie erst, wenn sie auch Ausfälle, Umwege und menschliche Grenzen einkalkuliert.',
  },
  {
    title: '3. Der Mensch trägt die Verantwortung',
    text: 'Werkzeuge sind nie nur Werkzeuge. Sie verändern Entscheidungen, Abhängigkeiten und Verantwortung. Deshalb müssen wir Technologie nicht nur entwickeln, sondern auch ihre Folgen gestalten.',
  },
];
---

<BaseLayout
  title='UX, KI & digitale Komplexität · Ralph Bolliger'
  imageAlt='Arbeitsplatz'
  imagePath={optimizedOgImage.src}
>
  <Section id='warum' margin='base'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>
        <a href='#warum' class='underline-offset-4 hover:underline'>Warum</a>
      </NormalText>
    </div>
    <div slot='right'>
      <LeadText weight='normal' spaceAfter='large'>
        Ich gestalte digitale Produkte für Menschen, die mit komplexen Systemen
        arbeiten. Mein Fokus liegt auf Klarheit, Sicherheit, Vertrauen und
        Handlungsfähigkeit. Technologie soll unterstützen, nicht blockieren.
      </LeadText>
      <LeadText weight='normal'>
        Komplexität verschwindet nicht durch gutes Design. Gutes Design
        entscheidet, ob sie beherrschbar bleibt. Ich helfe Organisationen dabei,
        digitale Systeme so zu bauen, dass sie verständlich, belastbar, sicher
        und nachhaltig nutzbar sind.</LeadText
      >
    </div>
  </Section>
  <Section id='wie' border='none'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>
        <a href='#wie' class='underline-offset-4 hover:underline'>Wie</a>
      </NormalText>
    </div>
    <div slot='right'>
      <Columns columns={howColumns} />
      <LargeText class='mt-base-double'>
        Technologie soll Orientierung schaffen, ohne Menschen abhängig,
        steuerbar oder austauschbar zu machen.
      </LargeText>
    </div>
  </Section>
  <Section id='laufbahn'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>
        <a href='#laufbahn' class='underline-offset-4 hover:underline'
          >Laufbahn</a
        >
      </NormalText>
    </div>
    <div slot='right'>
      <LargeText spaceAfter='large'
        >Mein Weg führt von digitaler Kommunikation über Projektleitung bis tief
        ins Product und Experience Design. Diese Kombination prägt meine Arbeit:
        Ich denke nicht nur in Benutzeroberflächen, sondern in Systemen,
        Abhängigkeiten und Entscheidungen.</LargeText
      >
      <LargeText spaceAfter='large'
        >Abseits von Kundenprojekten beschäftige ich mich mit Sicherheit,
        Verhaltenspsychologie, Philosophie, Ethik, Software und Elektrotechnik.
        Nicht als Selbstzweck, sondern weil all diese Themen dieselbe Frage
        berühren:</LargeText
      >
      <LargeText spaceAfter='large'>
        Wie bleibt Technologie menschlich, verständlich, verlässlich und sicher?</LargeText
      >
      <SplitList items={pathItems} />
    </div>
  </Section>
  <Section id='fokus'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>
        <a href='#fokus' class='underline-offset-4 hover:underline'>Fokus</a>
      </NormalText>
    </div>
    <div slot='right'>
      <LargeText class='mb-base-double'
        >Besonders stark bin ich in Projekten, in denen Design mehr leisten muss
        als gut auszusehen. Dort, wo Informationen kritisch sind, Prozesse
        komplex werden und Vertrauen davon abhängt, ob Menschen ein System
        wirklich verstehen.</LargeText
      >
      <Columns columns={focusItems} />
    </div>
  </Section>
  <Section id='ki'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>
        <a href='#ki' class='underline-offset-4 hover:underline'
          >KI & menschliche Fähigkeiten</a
        >
      </NormalText>
    </div>
    <div slot='right'>
      <LargeText class='mb-base-double'
        >Ich nutze KI pragmatisch, wenn sie Arbeit prüfbar beschleunigt,
        Perspektiven öffnet oder Barrieren senkt. Ihr Wert zeigt sich für mich
        nicht an Nutzung, Output oder Tokenverbrauch, sondern daran, ob Menschen
        bessere Entscheidungen treffen und Verantwortung behalten.</LargeText
      >
      <LargeText class='mb-base-double'
        >Gerade bei sensiblen Lösungen müssen Menschen nachvollziehen können,
        was ein System tut, wo seine Grenzen liegen und wer Verantwortung trägt.
        Technologie soll Fähigkeiten erweitern, nicht Organisationen von
        undurchsichtigen Systemen abhängig machen.</LargeText
      >
      <LargeText class='mb-base-double'
        >Die grösste Gefahr entsteht dort, wo Menschen sich daran gewöhnen, ihre
        Denkleistung dauerhaft an KI auszulagern. Wenn Ergebnisse ohne
        Verständnis übernommen werden, verkümmern Urteilsvermögen, Fachkompetenz
        und die Fähigkeit, Fehler überhaupt zu erkennen.</LargeText
      >
      <NormalText weight='bold' class='mt-base-double mb-base-double'
        >Meine Prinzipien</NormalText
      >
      <Columns columns={rulesOnAI} />
      <LargeText class='mt-base-double'
        >Neue Werkzeuge machen Menschen besser, nicht austauschbar.</LargeText
      >
    </div>
  </Section>
  <Section id='identität'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>
        <a href='#identität' class='underline-offset-4 hover:underline'
          >Identität</a
        >
      </NormalText>
    </div>
    <div slot='right'>
      <Image
        alt='Porträt von Ralph Bolliger'
        src={portrait}
        data-reveal
        class='mb-base-double rounded-2xl shadow-2xl'
      />
      <LargeText class='mb-base-double'
        >Ich veröffentliche keine direkten Kontaktdaten im Netz. Wenn du meine
        Identität prüfen oder einen sicheren und verschlüsselten
        Kommunikationskanal öffnen möchtest, bietet dir mein öffentlicher
        OpenPGP-Schlüssel eine Möglichkeit, mir eine E-Mail zukommen zu lassen:</LargeText
      >
      <NormalText>
        <a
          title='OpenPGP-Schlüssel öffnen'
          href='/pgp'
          class='font-mono text-accent underline underline-offset-4'
          rel='noreferrer'
          target='_blank'
        >
          FC84 CC79 8DD1 C935 6857<br />6F3B EE36 9AC6 9EF1 7BD8
        </a>
      </NormalText>
      <LargeText class='mt-base-double'
        >Wer mit sensiblen Systemen und Informationen arbeitet, sollte Identität
        nicht als Nebensache behandeln. Vertrauen beginnt damit, dass klar ist,
        mit wem man spricht.</LargeText
      >
    </div>
  </Section>
</BaseLayout>
