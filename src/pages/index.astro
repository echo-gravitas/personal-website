---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Columns from '../components/Columns.astro';
import Section from '../components/Section.astro';
import SplitList from '../components/SplitList.astro';
import LargeText from '../components/typography/LargeText.astro';
import LeadText from '../components/typography/LeadText.astro';
import NormalText from '../components/typography/NormalText.astro';
import portrait from '../images/portrait.jpg';

const howColumns = [
  {
    title: 'Experience Design',
    text: 'I design digital products that feel clear, useful and human—from early concepts to polished interfaces.',
  },
  {
    title: 'Security & Resilience',
    text: 'I explore systems, protocols and human behavior to better understand how technology can fail, and how to make it safer.',
  },
  {
    title: 'Independent Communication',
    text: 'I build and experiment with radio and communication systems where software, electronics and infrastructure meet.',
  },
];

const pathItems = [
  {
    label: 'Digital Communication',
    value:
      'Working in digital communication taught me how strongly technology influences attention, behavior, and trust.',
  },
  {
    label: 'Project Leadership',
    value:
      'Leading projects taught me how strategy, technology, people, and operational reality collide inside organizations.',
  },
  {
    label: 'Product & Experience Design',
    value:
      'Today, I design interfaces, workflows, and digital products that make complex systems easier to understand and use.',
  },
  {
    label: 'Independent Systems & Community',
    value:
      'Through amateur radio, security advocacy, software projects, and community work, I explore resilient communication and digital self-determination beyond centralized platforms.',
  },
];
const focusItems = [
  {
    title: 'Complex Interfaces',
    text: 'Products and systems where users need orientation, clarity, and confidence instead of unnecessary friction.',
  },
  {
    title: 'Responsible Digital Products',
    text: 'Design decisions involving privacy, transparency, resilience, autonomy, or sensitive workflows.',
  },
  {
    title: 'Systems & Communication',
    text: 'Projects involving resilient infrastructure, communication technology, independent systems, or technically demanding environments.',
  },
];
const rulesOnAI = [
  {
    title: 'Human capability must remain possible',
    text: 'AI should support human thinking, creativity, and decision making; not replace the ability to operate without automation.',
  },
  {
    title: 'Efficiency alone is not resilience',
    text: 'Systems optimized only for speed, scale, and cost often become fragile and dependent on infrastructure few people still understand.',
  },
  {
    title: 'Technology changes responsibility',
    text: 'Every technology reshapes how humans communicate, decide, work, and depend on each other. Those consequences should be considered before optimization becomes irreversible.',
  },
];
---

<BaseLayout title='Designing technology for humans - Ralph Bolliger'>
  <Section id='why' margin='base'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>Why</NormalText
      >
    </div>
    <div slot='right'>
      <LeadText weight='normal' spaceAfter='large'>
        I believe that digital technologies should expand human freedom, not
        diminish it. Because our identities, choices, and relationships are
        increasingly mediated by digital systems, control over our data and
        digital existence is essential for autonomy, dignity, and equitable
        participation in society.
      </LeadText>
      <LeadText weight='normal'>
        I design digital products and advocate for systems that uphold
        transparency, privacy, and user agency, enabling people to shape, not be
        shaped by, the digital world.</LeadText
      >
    </div>
  </Section>
  <Section id='how' border='none'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'>How</NormalText
      >
    </div>
    <div slot='right'>
      <Columns columns={howColumns} />
      <LargeText class='mt-base-double'>
        Going dark is no longer an option.
      </LargeText>
    </div>
  </Section>
  <Section id='practice'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'
        >Practice</NormalText
      >
    </div>
    <div slot='right'>
      <LargeText spaceAfter='large'
        >My work began in digital communication, evolved through project
        leadership, and gradually moved deeper into product and experience
        design. Outside client work, I explore behavioral psychology,
        philosophy, software development, radio communication, ethical hacking,
        and security research.</LargeText
      >
      <LargeText spaceAfter='large'
        >I approach these not as isolated interests, but as connected
        perspectives on how humans interact with technology and infrastructure.</LargeText
      >
      <NormalText weight='bold' class='mt-base-double mb-base-double'
        >Path</NormalText
      >
      <SplitList items={pathItems} />
      <LargeText class='mt-base'
        >Complexity is inevitable. Confusion is not.</LargeText
      >
    </div>
  </Section>
  <Section id='focus'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'
        >Focus</NormalText
      >
    </div>
    <div slot='right'>
      <LargeText class='mb-base-double'
        >I work best on projects where design, technology, and responsibility
        intersect. Especially where systems are complex, interfaces need
        clarity, or trust depends on how information is structured and
        communicated.</LargeText
      >
      <Columns columns={focusItems} />
    </div>
  </Section>
  <Section id='ai'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'
        >AI & Human Capability</NormalText
      >
    </div>
    <div slot='right'>
      <LargeText class='mb-base-double'
        >I use AI where it meaningfully improves workflows, communication, or
        accessibility. But I remain skeptical of replacing human understanding
        with permanent automation. Efficiency alone is not resilience.</LargeText
      >
      <LargeText class='mb-base-double'
        >A society that outsources too much thinking, decision making, and
        expertise to opaque systems risks losing the human capability required
        when those systems fail, become inaccessible, or economically
        unsustainable.</LargeText
      >
      <NormalText weight='bold' class='mt-base-double mb-base-double'
        >My principles for AI</NormalText
      >
      <Columns columns={rulesOnAI} />
      <LargeText class='mt-base-double'
        >Technology should strengthen human competence, not make it optional.</LargeText
      >
    </div>
  </Section>
  <Section id='identity'>
    <div slot='left'>
      <NormalText spaceAfter='small' weight='bold' tone='accent'
        >Identity</NormalText
      >
    </div>
    <div slot='right'>
      <Image
        alt='Portrait of myself'
        src={portrait}
        data-reveal
        class='mb-base-double rounded-2xl shadow-2xl'
      />
      <LargeText class='mb-base-double'
        >I do not publish direct contact channels publicly. If you need to
        verify my digital identity or establish a trusted communication channel,
        you can use my public OpenPGP key.</LargeText
      >
      <NormalText>
        <a
          title='Click to get OpenPGP key'
          href='/pgp'
          class='font-mono text-accent underline underline-offset-4'
          rel='noreferrer'
          target='_blank'
        >
          FC84 CC79 8DD1 C935 6857<br />6F3B EE36 9AC6 9EF1 7BD8
        </a>
      </NormalText>
      <LargeText class='mt-base-double'
        >Technology increasingly depends on trust. I believe identity should
        too.</LargeText
      >
    </div>
  </Section>
</BaseLayout>
