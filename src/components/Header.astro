---
import { SwatchBook } from '@lucide/astro';
---

<header
  class='sticky top-0 z-10 mx-auto mb-base md:mb-base-quadruple flex w-full items-center justify-between bg-page/50 py-base backdrop-blur-sm'
>
  <a
    href='/'
    aria-label='Home'
    class='inline-flex size-10 items-center justify-center rounded-full bg-accent'
  >
    <span class='logo-mark size-full p-base-half' aria-hidden='true'></span>
  </a>

  <nav class='flex items-center gap-base' aria-label='Hauptnavigation'>
    <a href='/blog' class='font-mono text-small text-accent hover:underline'>
      Blog
    </a>
    <button
      title='T drücken oder klicken, um das Theme zu wechseln'
      type='button'
      aria-label='T drücken oder klicken, um das Theme zu wechseln'
      data-theme-toggle
      class='inline-flex size-10 cursor-pointer items-center justify-center rounded-full text-accent'
    >
      <SwatchBook aria-hidden='true' />
    </button>
  </nav>
</header>
