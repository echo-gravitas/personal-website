---
import { Palette } from '@lucide/astro';
---

<header class='mx-auto flex w-full items-center justify-between py-base'>
  <a
    href='/'
    aria-label='Ralph Bolliger'
    class='inline-flex size-10 items-center justify-center rounded-full bg-accent'
  >
    <span class='logo-mark size-full p-base-half' aria-hidden='true'></span>
  </a>

  <button
    type='button'
    aria-label='Change mood'
    data-theme-toggle
    class='inline-flex size-10 cursor-pointer items-center justify-center rounded-full'
  >
    <Palette aria-hidden='true' size={20} />
  </button>
</header>
